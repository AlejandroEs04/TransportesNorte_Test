<Window x:Class="ADN_Test.Views.EmbarqueDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:viewmodels="clr-namespace:ADN_Test.ViewModels" d:DataContext="{d:DesignInstance Type=viewmodels:EmbarqueDetailViewModel}"
        mc:Ignorable="d"
        Title="Detalle de Embarque" Height="520" Width="600"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="{Binding Folio, StringFormat='Embarque: {0}'}" 
                   FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <GroupBox Header="Resumen" Margin="0,0,0,10" Padding="10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Placa Tracto:" FontWeight="Bold" Margin="0,0,5,5"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Placa_Tracto}" Margin="0,0,0,5"/>

                        <TextBlock Grid.Row="1" Grid.Column="2" Text="Conductor:" FontWeight="Bold" Margin="0,0,5,5"/>
                        <TextBlock Grid.Row="1" Grid.Column="3" Text="{Binding Nombre_Conductor}" Margin="0,0,15,5"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Peso Teórico ERP:" FontWeight="Bold" Margin="0,0,5,5"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding Peso_Teorico_ERP}" Margin="0,0,15,5"/>
                    </Grid>
                </GroupBox>

                <GroupBox Header="Completar Pesaje de Salida" Padding="10">
                    <StackPanel>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Peso Báscula Salida:" FontWeight="Bold" Margin="0,0,10,10" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="0" PreviewTextInput="NumberValidationTextBox" Grid.Column="1" Text="{Binding Peso_Bascula_Salida, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:F0}}" Margin="0,0,0,10" Height="25" />

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Peso Neto Real:" FontWeight="Bold" Margin="0,0,10,10" VerticalAlignment="Center"/>
                            <TextBox IsReadOnly="True" Grid.Row="1" PreviewTextInput="NumberValidationTextBox" Grid.Column="1" Text="{Binding Peso_Neto_Real, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10" Height="25"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Justificación Diferencia:" FontWeight="Bold" Margin="0,0,10,0" VerticalAlignment="Top"/>
                            <TextBox Grid.Row="2" Grid.Column="1" IsEnabled="{Binding RequireJustification}" Text="{Binding Justificacion_Diferencia, UpdateSourceTrigger=PropertyChanged}" 
                                     AcceptsReturn="True" TextWrapping="Wrap" Height="80" VerticalScrollBarVisibility="Auto"/>
                        </Grid>
                    </StackPanel>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Autorizar Salida" Command="{Binding GuardarCommand}" Width="100" Height="30" Margin="0,0,10,0" IsEnabled="{Binding EnableSaveButton}"/>
            <Button Content="Cerrar" Command="{Binding CerrarCommand}" Width="100" Height="30"/>

            <TextBlock Text="{Binding ErrorMessage}" Foreground="Red" VerticalAlignment="Center" Margin="10,0,0,0"/>
        </StackPanel>
    </Grid>
</Window>
