<Window x:Class="ADN_Test.Views.CreateEmbarqueWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:viewmodels="clr-namespace:ADN_Test.ViewModels" d:DataContext="{d:DesignInstance Type=viewmodels:CreateEmbarqueViewModel}"
        mc:Ignorable="d"
        Title="Nuevo Embarque" Height="450" Width="550"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Window.Resources>
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Registrar Nuevo Embarque"
                   FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <GroupBox Header="Datos del Embarque" Padding="10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Centro Operativo:" FontWeight="Bold" Margin="0,0,10,10" VerticalAlignment="Center"/>
                        <ComboBox Grid.Row="0" Grid.Column="1" ItemsSource="{Binding CentrosOperativos}" 
                                  SelectedItem="{Binding SelectedCentroOperativo}" 
                                  DisplayMemberPath="Nombre" 
                                  Margin="0,0,0,10" Height="30" MinWidth="200"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Tracto:" FontWeight="Bold" Margin="0,0,10,10" VerticalAlignment="Center"/>
                        <ComboBox Grid.Row="1" Grid.Column="1" ItemsSource="{Binding Tractos}" 
                                  SelectedItem="{Binding SelectedTracto}" 
                                  DisplayMemberPath="Placa_Tracto" 
                                  Margin="0,0,0,10" Height="30" MinWidth="200"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Conductor:" FontWeight="Bold" Margin="0,0,10,10" VerticalAlignment="Center"/>
                        <ComboBox Grid.Row="2" Grid.Column="1" ItemsSource="{Binding Conductores}" 
                                  SelectedItem="{Binding SelectedConductor}" 
                                  DisplayMemberPath="Nombre_Completo" 
                                  Margin="0,0,0,10" Height="30" MinWidth="200"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Peso Teórico ERP:" FontWeight="Bold" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding PesoTeoricoERP, UpdateSourceTrigger=PropertyChanged}" 
                                 PreviewTextInput="NumberValidationTextBox" Height="25" Margin="0,0,0,0"/>
                    </Grid>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="1" Background="#80FFFFFF" Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
            <TextBlock Text="Cargando..." HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="24"/>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Registrar" Command="{Binding GuardarCommand}" Width="100" Height="30" Margin="0,0,10,0"/>
            <Button Content="Cancelar" Command="{Binding CerrarCommand}" Width="100" Height="30"/>
        </StackPanel>

        <TextBlock Grid.Row="2" Text="{Binding ErrorMessage}" Foreground="Red" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="0,15,0,0"/>
    </Grid>
</Window>
